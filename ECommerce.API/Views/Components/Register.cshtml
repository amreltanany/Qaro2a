@{
    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var isArabic = string.Equals(currentCulture, "ar", StringComparison.OrdinalIgnoreCase);
    string L(string en, string ar) => isArabic ? ar : en;
    ViewData["Title"] = L("Register", "إنشاء حساب");
}

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <h2 class="text-center mb-4">@L("Register", "إنشاء حساب")</h2>
                <div id="registerError" class="alert alert-danger d-none" role="alert"></div>
                <form id="registerForm">
                    <div class="mb-3">
                        <label for="fullName" class="form-label">@L("Full name", "الاسم الكامل")</label>
                        <input type="text" class="form-control" id="fullName" name="fullName" required>
                    </div>
                    <div class="mb-3">
                        <label for="email" class="form-label">@L("Email", "البريد الإلكتروني")</label>
                        <input type="email" class="form-control" id="email" name="email" required>
                    </div>
                    <div class="mb-3">
                        <label for="password" class="form-label">@L("Password", "كلمة المرور")</label>
                        <input type="password" class="form-control" id="password" name="password" required minlength="6">
                    </div>
                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input m-1" id="agreeToTerms" name="agreeToTerms" value="true" required>
                        <label class="form-check-label" for="agreeToTerms">
                            @L("I agree to the", "أوافق على")
                            <a asp-controller="Home" asp-action="TermsOfService" target="_blank" rel="noopener noreferrer">@L("Terms of Service", "شروط الخدمة")</a>
                        </label>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">@L("Register", "إنشاء حساب")</button>
                </form>
                <p class="mt-3 text-center small">
                    @L("Already have an account?", "لديك حساب بالفعل؟") <a asp-controller="Home" asp-action="Login">@L("Login", "تسجيل الدخول")</a>
                </p>
            </div>
        </div>
    </div>
</section>

<script>
var i18n = {
    fallbackError: '@L("Something went wrong. Please try again.", "حدث خطأ ما. حاول مرة أخرى.")',
    mustAgree: '@L("You must agree to the Terms of Service.", "يجب الموافقة على شروط الخدمة.")',
    couldNotGetUser: '@L("Could not get user", "تعذر تحميل بيانات المستخدم")',
    registerFailed: '@L("Register failed", "فشل إنشاء الحساب")'
};
function parseApiErrorResponse(res) {
    return res.text().then(function (text) {
        var fallback = i18n.fallbackError;
        var t = (text || '').trim();
        if (!t) return fallback;
        if (t.charAt(0) === '{' || t.charAt(0) === '[') {
            try {
                var d = JSON.parse(t);
                if (d && typeof d === 'object') {
                    if (d.message) return d.message;
                    if (d.title && d.title !== 'One or more validation errors occurred.') return d.title;
                    if (d.detail) return d.detail;
                    if (d.errors) {
                        var keys = Object.keys(d.errors);
                        if (keys.length && Array.isArray(d.errors[keys[0]]) && d.errors[keys[0]][0])
                            return d.errors[keys[0]][0];
                    }
                }
            } catch (e) { /* ignore */ }
        }
        return t;
    });
}

document.getElementById('registerForm').addEventListener('submit', function (e) {
    e.preventDefault();
    var errEl = document.getElementById('registerError');
    errEl.classList.add('d-none');
    var fullName = document.getElementById('fullName').value;
    var email = document.getElementById('email').value;
    var password = document.getElementById('password').value;
    var agreeToTerms = document.getElementById('agreeToTerms').checked;
    if (!agreeToTerms) {
        errEl.textContent = i18n.mustAgree;
        errEl.classList.remove('d-none');
        return;
    }

    fetch('/api/Account/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email, password: password, fullName: fullName, agreeToTerms: agreeToTerms })
    })
    .then(function (res) {
        if (!res.ok) return parseApiErrorResponse(res).then(function (msg) { throw new Error(msg); });
        return res.json();
    })
    .then(function (data) {
        localStorage.setItem('token', data.token);
        var expires = new Date();
        expires.setDate(expires.getDate() + 7);
        document.cookie = 'token=' + encodeURIComponent(data.token) + '; path=/; expires=' + expires.toUTCString() + '; SameSite=Lax';
        return fetch('/api/Account/me', {
            headers: { 'Authorization': 'Bearer ' + data.token }
        });
    })
    .then(function (res) {
        if (!res.ok) throw new Error(i18n.couldNotGetUser);
        return res.json();
    })
    .then(function (data) {
        localStorage.setItem('userId', data.userId);
        window.location.href = '/Home/Shop';
    })
    .catch(function (err) {
        errEl.textContent = err.message || i18n.registerFailed;
        errEl.classList.remove('d-none');
    });
});
</script>
