@{
    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var isArabic = string.Equals(currentCulture, "ar", StringComparison.OrdinalIgnoreCase);
    string L(string en, string ar) => isArabic ? ar : en;
    ViewData["Title"] = L("About", "من نحن");
}
<link rel="stylesheet" type="text/css" href="~/Blog.css" asp-append-version="true">

<main class="main">
    <div class="page-title">
      <div class="container d-lg-flex justify-content-between align-items-center">
        <h1 class="mb-2 mb-lg-0">@L("About", "من نحن")</h1>
      </div>
    </div>

    <section id="about" class="about section py-5">
      <div class="container">

        <div class="row gy-4">

          <div class="col-lg-6 content" data-aos="fade-up" data-aos-delay="100">
            <p class="who-we-are">@L("Who We Are", "من نحن")</p>
            <h3>@L("The Ultimate Hub for Books, Publishing & Dialogue", "المركز الأهم للكتب والنشر والحوار")</h3>
            <p class="fst-italic">
            @L("At Qaro2a, we are a premier literary hub shaping the future of reading. As a dynamic podcast, insightful book reviewer, and forward thinking publisher, we are dedicated to championing books and empowering the entire literary ecosystem. Through engaging discussions and strategic support, we bridge the gap between creative authors and passionate readers.", "في قاروعه نحن منصة أدبية رائدة تسهم في تشكيل مستقبل القراءة. من خلال البودكاست والمراجعات والنشر، نعمل على دعم الكتب وتمكين المنظومة الأدبية بالكامل. وبالحوار البنّاء والدعم الفعّال نربط بين المؤلفين المبدعين والقراء الشغوفين.")
            </p>
            <ul>
              <li><i class="bi bi-check-circle"></i> <span>@L("Leading Podcast & Reviews: Decoding stories and analyzing books with a modern, engaging approach.", "بودكاست ومراجعات رائدة: نفكك الحكايات ونحلل الكتب بأسلوب حديث وجذاب.")</span></li>
              <li><i class="bi bi-check-circle"></i> <span>@L("Publishers of Fresh Voices: Bringing impactful contemporary literature to light and supporting authors.", "نشر الأصوات الجديدة: نُبرز الأدب المعاصر المؤثر وندعم المؤلفين.")</span></li>
              <li><i class="bi bi-check-circle"></i> <span>@L("Advocates for the Reading Community: Fostering a powerful, supportive ecosystem for every book lover.", "داعمون لمجتمع القراءة: نبني بيئة قوية وداعمة لكل محب للكتاب.")</span></li>
            </ul>
          </div>

          <div class="col-lg-6 about-images" data-aos="fade-up" data-aos-delay="200">
            <div class="row gy-4">
              <div class="col-lg-6">
                <img src="@Url.Content("~/blog_img/about-hero.jpeg")" class="img-fluid" alt="Qaro2a team" asp-append-version="true" />
              </div>
              <div class="col-lg-6">
                <div class="row gy-4">
                  <div class="col-lg-12">
                    <img src="@Url.Content("~/blog_img/about-gallery-1.png")" class="img-fluid" alt="Qaro2a event" asp-append-version="true" />
                  </div>
                  <div class="col-lg-12">
                    <img src="@Url.Content("~/blog_img/about-gallery-2.png")" class="img-fluid" alt="Qaro2a community" asp-append-version="true" />
                  </div>
                </div>
              </div>
            </div>

          </div>

        </div>

      </div>
    </section>

    <section id="team" class="team section py-5">

      <div class="container section-title" data-aos="fade-up">
        <div class="section-title-container d-flex align-items-center justify-content-between">
          <h2>@L("Team", "الفريق")</h2>
        </div>
      </div>

      <div class="container">

        <div class="row gy-4">

