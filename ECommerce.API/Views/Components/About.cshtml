                </div>
              </div>
            </div>
          </div>

          <div class="col-lg-6" data-aos="fade-up" data-aos-delay="300">
            <div class="team-member d-flex align-items-start">
              <div class="pic"><img src="@Url.Content("~/blog_img/team/Mamdouh.png")" class="img-fluid" alt="Mamdouh" asp-append-version="true" /></div>
              <div class="member-info">
                <h4>Mamdouh</h4>
                <span>@L("Team Member", "عضو بالفريق")</span>
                <p>@L("Editor and publishing coordinator.", "محرر ومنسق نشر.")</p>
                <div class="social">
                  <a href=""><i class="bi bi-twitter-x"></i></a>
                  <a href=""><i class="bi bi-facebook"></i></a>
                  <a href=""><i class="bi bi-instagram"></i></a>
                  <a href=""><i class="bi bi-linkedin"></i></a>
                </div>
              </div>
            </div>
          </div>

          <div class="col-lg-6" data-aos="fade-up" data-aos-delay="400">
            <div class="team-member d-flex align-items-start">
              <div class="pic"><img src="@Url.Content("~/blog_img/team/Rana.png")" class="img-fluid" alt="Rana" asp-append-version="true" /></div>
              <div class="member-info">
                <h4>Rana</h4>
                <span>@L("Team Member", "عضو بالفريق")</span>
                <p>@L("Podcast host and reviewer.", "مقدمة بودكاست وناقدة كتب.")</p>
                <div class="social">
                  <a href=""><i class="bi bi-twitter-x"></i></a>
                  <a href=""><i class="bi bi-facebook"></i></a>
