@model IEnumerable<ECommerce.Application.DTOs.Wishlist.WishlistItemDto>

@{
    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var isArabic = string.Equals(currentCulture, "ar", StringComparison.OrdinalIgnoreCase);
    string L(string en, string ar) => isArabic ? ar : en;
    ViewData["Title"] = L("Wishlist", "المفضلة");
}

<link rel="stylesheet" href="~/css/wishlist.css" asp-append-version="true" />

<section class="wishlist-section">
    <div class="container">
        <h2 class="mb-4">@L("My Wishlist", "مفضلتي")</h2>

        @if (Model == null || !Model.Any())
        {
            <div class="wishlist-empty">
                @L("Your wishlist is empty.", "قائمة المفضلة فارغة.") <a asp-controller="Home" asp-action="Shop">@L("Discover books", "اكتشف الكتب")</a>.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle wishlist-table">
                    <thead>
                        <tr>
                            <th>@L("Item", "المنتج")</th>
                            <th>@L("Price", "السعر")</th>
                            <th>@L("Stock", "المخزون")</th>
                            <th class="text-end">@L("Action", "الإجراء")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr data-item-id="@item.Id">
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="@Url.Content(item.ImageUrl ?? "~/logo/Untitled_design-removebg-preview.png")"
                                             alt="@item.ProductName" class="wishlist-thumb" />
                                        <div>
                                            <div class="fw-semibold">@item.ProductName</div>
                                            <div class="small text-muted">@item.Description</div>
                                        </div>
                                    </div>
                                </td>
                                <td>@item.Price.ToString("C")</td>
                                <td>
                                    @if (item.AvailableStock > 0)
                                    {
                                        <span class="badge bg-success">@L("In stock", "متوفر")</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary" style="background-color: #dc3545 !important;" >@L("Out of stock", "غير متوفر")</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <button type="button" class="wishlist-remove btn-remove-wishlist" title="@L("Remove", "حذف")">×</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <a asp-controller="Home" asp-action="Shop" class="btn btn-outline-primary mt-2">@L("Continue shopping", "متابعة التسوق")</a>
        }
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            var token = typeof localStorage !== 'undefined' && localStorage.getItem('token');
            var i18n = {
                failedRemove: '@L("Failed to remove item.", "فشل حذف المنتج.")'
            };
            function authHeaders() {
                return {
                    'Content-Type': 'application/json',
                    'Authorization': 'Bearer ' + token
                };
            }

            document.querySelectorAll('.btn-remove-wishlist').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var row = this.closest('tr');
                    var itemId = row.getAttribute('data-item-id');
                    if (!token) {
                        window.location.href = '/Home/Login';
                        return;
                    }

                    fetch('/api/Wishlist/items/' + itemId, {
                        method: 'DELETE',
                        headers: authHeaders()
                    })
                        .then(function (res) {
                            if (!res.ok) {
                                return res.json().then(function (body) {
                                    var msg = (body && body.message) ? body.message : i18n.failedRemove;
                                    alert(msg);
                                }).catch(function () { alert(i18n.failedRemove); });
                            }
                            window.location.reload();
                        })
                        .catch(function (err) {
                            console.error(err);
                            alert(i18n.failedRemove);
                        });
                });
            });
        })();
    </script>
}
