@model IEnumerable<ECommerce.Application.DTOs.Cart.CartItemDto>

@{
    ViewData["Title"] = "Cart";
}

<section class="py-5">
    <div class="container">
        <h2 class="mb-4">Your Cart</h2>

        @if (TempData["CartError"] is string cartError)
        {
            <div class="alert alert-warning" role="alert">@cartError</div>
        }

        @if (Model == null || !Model.Any())
        {
            <div class="text-muted">
                Your cart is empty. <a asp-controller="Home" asp-action="Shop">Continue shopping</a>.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Product Name</th>
                            <th>Price</th>
                            <th>Quantity</th>
                            <th class="text-end">Subtotal</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var atMaxStock = item.Quantity >= item.AvailableStock;
                            <tr data-item-id="@item.Id" data-max-stock="@item.AvailableStock">
                                <td>@item.ProductName</td>
                                <td>@item.Price.ToString("N2") EGP</td>
                                <td>
                                    <div class="d-flex align-items-center gap-1 flex-wrap">
                                        <button type="button" class="btn btn-sm btn-outline-secondary cart-qty-minus" aria-label="Decrease quantity">−</button>
                                        <span class="cart-qty-value px-2" style="min-width: 2rem; text-align: center;">@item.Quantity</span>
                                        <button type="button" class="btn btn-sm btn-outline-secondary cart-qty-plus @(atMaxStock ? "disabled" : "")" aria-label="Increase quantity" @(atMaxStock ? "disabled" : null)>+</button>
                                    </div>
                                    
                                </td>
                                <td class="text-end cart-subtotal">@item.Subtotal.ToString("N2") EGP</td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-outline-danger cart-remove-item" aria-label="Remove item" title="Remove">×</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <p class="mt-3">
                <a asp-controller="Home" asp-action="Shop" class="btn btn-outline-primary">Continue shopping</a>
                <a asp-controller="Cart" asp-action="Checkout" class="btn btn-primary ms-2">Checkout</a>
            </p>
        }
    </div>
</section>

@section Scripts {
    <script src="~/js/cart.js"></script>
}
