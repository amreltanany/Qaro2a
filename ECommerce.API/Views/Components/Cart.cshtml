@model IEnumerable<ECommerce.Application.DTOs.Cart.CartItemDto>

@{
    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var isArabic = string.Equals(currentCulture, "ar", StringComparison.OrdinalIgnoreCase);
    string L(string en, string ar) => isArabic ? ar : en;
    ViewData["Title"] = L("Cart", "السلة");
}

<section class="py-5">
    <div class="container">
        <h2 class="mb-4">@L("Your Cart", "سلة التسوق")</h2>

        @if (TempData["CartError"] is string cartError)
        {
            <div class="alert alert-warning" role="alert">@cartError</div>
        }

        @if (Model == null || !Model.Any())
        {
            <div class="text-muted">
                @L("Your cart is empty.", "سلة التسوق فارغة.") <a asp-controller="Home" asp-action="Shop">@L("Continue shopping", "متابعة التسوق")</a>.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>@L("Product Name", "اسم المنتج")</th>
                            <th>@L("Price", "السعر")</th>
                            <th>@L("Quantity", "الكمية")</th>
                            <th class="text-end">@L("Subtotal", "الإجمالي الفرعي")</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var atMaxStock = item.Quantity >= item.AvailableStock;
                            <tr data-item-id="@item.Id" data-max-stock="@item.AvailableStock">
                                <td>@item.ProductName</td>
                                <td>@item.Price.ToString("N2") EGP</td>
                                <td>
                                    <div class="d-flex align-items-center gap-1 flex-wrap">
                                        <button type="button" class="btn btn-sm btn-outline-secondary cart-qty-minus" aria-label="@L("Decrease quantity", "تقليل الكمية")">−</button>
                                        <span class="cart-qty-value px-2" style="min-width: 2rem; text-align: center;">@item.Quantity</span>
                                        <button type="button" class="btn btn-sm btn-outline-secondary cart-qty-plus @(atMaxStock ? "disabled" : "")" aria-label="@L("Increase quantity", "زيادة الكمية")" @(atMaxStock ? "disabled" : null)>+</button>
                                    </div>
                                    
                                </td>
                                <td class="text-end cart-subtotal">@item.Subtotal.ToString("N2") EGP</td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-outline-danger cart-remove-item" aria-label="@L("Remove item", "حذف المنتج")" title="@L("Remove", "حذف")">×</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <p class="mt-3">
                <a asp-controller="Home" asp-action="Shop" class="btn btn-outline-primary">@L("Continue shopping", "متابعة التسوق")</a>
                <a asp-controller="Cart" asp-action="Checkout" class="btn btn-primary ms-2">@L("Checkout", "إتمام الطلب")</a>
            </p>
        }
    </div>
</section>

@section Scripts {
    <script src="~/js/cart.js"></script>
}
