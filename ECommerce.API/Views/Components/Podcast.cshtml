@{
    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var isArabic = string.Equals(currentCulture, "ar", StringComparison.OrdinalIgnoreCase);
    string L(string en, string ar) => isArabic ? ar : en;
    ViewData["Title"] = L("Podcast", "بودكاست");
}

<section class="podcast-page py-4 py-md-5" style="background: #0b1220; min-height: 100vh;">
    <div class="container px-3 px-md-4">
        <div class="text-center text-white mb-4 mb-md-5 px-2">
            <h1 class="mb-2">@L("Podcast", "بودكاست")</h1>
            <p class="mb-0">@L("Watch the latest videos from Qaro2a.", "شاهد أحدث فيديوهات قروءه.")</p>
        </div>

        <div class="row g-4">
            <div class="col-12 col-lg-4">
                <div class="ratio ratio-16x9 rounded overflow-hidden shadow">
                    <iframe src="https://www.youtube.com/embed/sVBZDAQQGCk?rel=0"
                            title="Qaro2a Video 1" loading="lazy"
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                            referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
                </div>
            </div>
