@{
    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var isArabic = string.Equals(currentCulture, "ar", StringComparison.OrdinalIgnoreCase);
    string L(string en, string ar) => isArabic ? ar : en;
    ViewData["Title"] = L("Terms of Service", "شروط الخدمة");
}

<main class="main">
    <div class="page-title">
        <div class="container d-lg-flex justify-content-between align-items-center">
            <h1 class="mb-2 mb-lg-0">@L("Terms of Service", "شروط الخدمة")</h1>
        </div>
    </div>

    <section class="section py-5">
        <div class="container" style="max-width: 840px;">
            <p class="text-muted small mb-4">@L("Last updated: March 28, 2026", "آخر تحديث: 28 مارس 2026")</p>

            <p>
                These Terms of Service (“Terms”) govern your access to and use of the Qaro2a website, mobile experiences,
                and related services (collectively, the “Services”). By accessing or using the Services, you agree to these
                Terms. If you do not agree, do not use the Services.
            </p>

            <h2 class="h4 mt-4">@L("Eligibility and accounts", "الأهلية والحسابات")</h2>
            <p>
                You must be able to form a binding contract under applicable law to use the Services. You are responsible
                for maintaining the confidentiality of your account credentials and for all activity under your account.
                Notify us promptly of any unauthorized use.
            </p>

            <h2 class="h4 mt-4">@L("Products, pricing, and availability", "المنتجات والأسعار والتوفر")</h2>
            <p>
                We strive to display accurate product information, images, and prices. Errors may occur; we reserve the
                right to correct pricing or description errors, cancel orders affected by such errors, and limit quantities.
                Availability is not guaranteed until an order is confirmed.
            </p>

            <h2 class="h4 mt-4">@L("Orders and payment", "الطلبات والدفع")</h2>
            <p>
                When you place an order, you offer to purchase the items in your cart subject to these Terms. We may accept
                or decline orders in our discretion. Payment is processed through our designated payment methods. You agree
                to provide current, complete, and accurate purchase and account information.
            </p>

            <h2 class="h4 mt-4">@L("Shipping and returns", "الشحن والإرجاع")</h2>
            <p>
                Shipping timelines and costs, if any, are provided at checkout or in our policies as updated from time to
                time. Return, refund, and exchange rules are as stated on our site at the time of purchase unless otherwise
                required by law.
            </p>

            <h2 class="h4 mt-4">@L("Prohibited conduct", "السلوك المحظور")</h2>
            <p>@L("You agree not to:", "تتعهد بعدم:")</p>
            <ul>
                <li>use the Services for any unlawful purpose or in violation of these Terms;</li>
                <li>attempt to gain unauthorized access to our systems, other users’ accounts, or data;</li>
                <li>interfere with or disrupt the Services or servers or networks connected to the Services;</li>
                <li>use automated means to scrape, harvest, or collect data from the Services without our prior written consent;</li>
                <li>misrepresent your identity or affiliation.</li>
            </ul>

            <h2 class="h4 mt-4">@L("Intellectual property", "الملكية الفكرية")</h2>
            <p>
                The Services and their content (including text, graphics, logos, and software) are owned by Qaro2a or its
                licensors and are protected by intellectual property laws. You receive a limited, non-exclusive,
                non-transferable license to access and use the Services for personal, non-commercial shopping purposes.
            </p>

            <h2 class="h4 mt-4">@L("Disclaimer of warranties", "إخلاء المسؤولية عن الضمانات")</h2>
            <p>
                THE SERVICES ARE PROVIDED “AS IS” AND “AS AVAILABLE” WITHOUT WARRANTIES OF ANY KIND, EITHER EXPRESS OR
                IMPLIED, INCLUDING IMPLIED WARRANTIES OF MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE, AND
                NON-INFRINGEMENT, TO THE FULLEST EXTENT PERMITTED BY LAW.
            </p>

            <h2 class="h4 mt-4">@L("Limitation of liability", "تحديد المسؤولية")</h2>
            <p>
                TO THE MAXIMUM EXTENT PERMITTED BY APPLICABLE LAW, QARO2A AND ITS AFFILIATES, OFFICERS, EMPLOYEES, AND AGENTS
                SHALL NOT BE LIABLE FOR ANY INDIRECT, INCIDENTAL, SPECIAL, CONSEQUENTIAL, OR PUNITIVE DAMAGES, OR ANY LOSS
                OF PROFITS, DATA, OR GOODWILL, ARISING FROM YOUR USE OF THE SERVICES. OUR TOTAL LIABILITY FOR ANY CLAIM
                ARISING OUT OF THESE TERMS OR THE SERVICES SHALL NOT EXCEED THE GREATER OF THE AMOUNT YOU PAID TO US FOR
                THE TRANSACTION GIVING RISE TO THE CLAIM OR ONE HUNDRED DOLLARS (USD $100), EXCEPT WHERE PROHIBITED BY LAW.
            </p>

            <h2 class="h4 mt-4">@L("Indemnity", "التعويض")</h2>
            <p>
                You agree to defend, indemnify, and hold harmless Qaro2a and its affiliates from claims, damages, losses,
                and expenses (including reasonable attorneys’ fees) arising from your use of the Services, your violation of
                these Terms, or your violation of any third-party rights.
            </p>

            <h2 class="h4 mt-4">@L("Governing law and disputes", "القانون المنظم وتسوية النزاعات")</h2>
            <p>
                These Terms are governed by the laws applicable in your jurisdiction as we may specify in a separate
                notice, without regard to conflict-of-law principles. Any disputes shall be resolved in the courts of
                competent jurisdiction as required by applicable law, unless a different mandatory forum applies to
                consumers in your region.
            </p>

            <h2 class="h4 mt-4">@L("Changes", "التعديلات")</h2>
            <p>
                We may modify these Terms at any time. We will post the updated Terms on this page and update the “Last
                updated” date. Your continued use of the Services after changes become effective constitutes acceptance of
                the revised Terms where permitted by law.
            </p>

            <h2 class="h4 mt-4">@L("Contact", "التواصل")</h2>
            <p>
                For questions about these Terms, contact us at
                <a asp-controller="Contact" asp-action="Index">support@qaro2a.com</a>.
            </p>
        </div>
    </section>
</main>
