@model ECommerce.API.ViewModels.MyAccountViewModel
@{
    ViewData["Title"] = "My Account";
}

<style>
    .account-section {
        padding: 48px 0;
    }

    .account-card {
        border: 1px solid #e9ecef;
        border-radius: 10px;
        padding: 1.5rem;
        background: #fff;
        margin-bottom: 1.5rem;
    }

    .account-card h3 {
        font-size: 1.1rem;
        margin-bottom: 1rem;
        font-weight: 600;
    }

    .order-card {
        border: 1px solid #e9ecef;
        border-radius: 8px;
        margin-bottom: 1rem;
        overflow: hidden;
    }

    .order-card-header {
        background: #f8f9fa;
        padding: 0.75rem 1rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1.5rem;
        align-items: center;
        font-size: 0.9rem;
    }

    .order-items-table th {
        font-size: 0.85rem;
        font-weight: 600;
    }

    .account-danger {
        border-color: #f5c2c7;
        background: #fff5f5;
    }
</style>

<section class="account-section">
    <div class="container">
        <h2 class="mb-4">My account</h2>

        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <div class="alert alert-success" role="alert">@Model.StatusMessage</div>
        }
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
        }

        <div class="row g-4">
            <div class="col-lg-5">
                <div class="account-card">
                    <h3>Profile</h3>
                    <form asp-controller="Home" asp-action="UpdateProfile" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="text" class="form-control" value="@Model.Email" disabled readonly />
                            <div class="form-text">Email cannot be changed here.</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="fullName">Full name</label>
                            <input type="text" class="form-control" id="fullName" name="fullName" value="@Model.FullName"
                                required maxlength="200" />
                        </div>
                        <hr class="my-3" />
                        <p class="small text-muted mb-2">Change password (optional)</p>
                        <div class="mb-3">
                            <label class="form-label" for="currentPassword">Current password</label>
                            <input type="password" class="form-control" id="currentPassword" name="currentPassword"
                                autocomplete="current-password" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="newPassword">New password</label>
                            <input type="password" class="form-control" id="newPassword" name="newPassword"
                                minlength="6" autocomplete="new-password" />
                        </div>
                        <button type="submit" class="btn btn-primary">Save changes</button>
                    </form>
                    <hr class="my-3" />
                    <p class="small text-muted mb-2">End your session on this device.</p>
                    <button type="button" id="logoutLink" class="btn btn-outline-secondary">
                        <i class="bi bi-box-arrow-right me-2"></i>Log out
                    </button>
                </div>

                <div class="account-card account-danger">
                    <h3 class="text-danger">Delete account</h3>
                    <p class="small text-muted mb-3">This permanently removes your profile, orders history shown here,
                        and related data tied to your login. This cannot be undone.</p>
                    <form asp-controller="Home" asp-action="DeleteAccount" method="post"
                        onsubmit="return confirm('Delete your account permanently?');">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label" for="deletePassword">Confirm with password</label>
                            <input type="password" class="form-control" id="deletePassword" name="deletePassword"
                                required autocomplete="current-password" />
                        </div>
                        <button type="submit" class="btn btn-outline-danger">Delete my account</button>
                    </form>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="account-card">
                    <h3>My orders</h3>
                    @if (Model.Orders == null || !Model.Orders.Any())
                    {
                        <p class="text-muted mb-0">You have no orders yet. <a asp-controller="Home"
                                asp-action="Shop">Browse the shop</a>.</p>
                    }
                    else
                    {
                        @foreach (var order in Model.Orders)
                        {
                            <div class="order-card">
                                <div class="order-card-header">
                                    <strong>Order #@order.Id</strong>
                                    <span>@order.OrderDate.ToLocalTime().ToString("g")</span>
                                    <span class="badge bg-secondary">@order.Status</span>
                                    <span class="ms-auto fw-semibold">@order.TotalAmount.ToString("C")</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(order.ShippingAddress) ||
                                                                !string.IsNullOrWhiteSpace(order.ShippingPhone))
                                {
                                    <div class="px-3 py-2 small border-bottom bg-white">
                                        @if (!string.IsNullOrWhiteSpace(order.ShippingAddress))
                                        {
                                            <div><span class="text-muted">Ship to:</span> @order.ShippingAddress</div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(order.ShippingPhone))
                                        {
                                            <div><span class="text-muted">Phone:</span> @order.ShippingPhone</div>
                                        }
                                    </div>
                                }
                                <div class="table-responsive">
                                    <table class="table table-sm mb-0 order-items-table">
                                        <thead>
                                            <tr>
                                                <th>Product</th>
                                                <th class="text-end">Price</th>
                                                <th class="text-end">Qty</th>
                                                <th class="text-end">Subtotal</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var line in order.Items)
                                            {
                                                <tr>
                                                    <td>@line.ProductName</td>
                                                    <td class="text-end">@line.Price.ToString("C")</td>
                                                    <td class="text-end">@line.Quantity</td>
                                                    <td class="text-end">@line.Subtotal.ToString("C")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</section>
