@model ECommerce.API.ViewModels.MyAccountViewModel
@{
    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var isArabic = string.Equals(currentCulture, "ar", StringComparison.OrdinalIgnoreCase);
    string L(string en, string ar) => isArabic ? ar : en;
    ViewData["Title"] = L("My Account", "حسابي");
}

<link rel="stylesheet" href="~/css/account.css" asp-append-version="true" />

<section class="account-section">
    <div class="container">
        <h2 class="mb-4">@L("My account", "حسابي")</h2>

        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <div class="alert alert-success" role="alert">@Model.StatusMessage</div>
        }
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
        }

        <div class="row g-4">
            <div class="col-lg-5">
                <div class="account-card">
                    <h3>@L("Profile", "الملف الشخصي")</h3>
                    <form asp-controller="Home" asp-action="UpdateProfile" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label">@L("Email", "البريد الإلكتروني")</label>
                            <input type="text" class="form-control" value="@Model.Email" disabled readonly />
                            <div class="form-text">@L("Email cannot be changed here.", "لا يمكن تغيير البريد الإلكتروني من هنا.")</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="fullName">@L("Full name", "الاسم الكامل")</label>
                            <input type="text" class="form-control" id="fullName" name="fullName" value="@Model.FullName"
                                required maxlength="200" />
                        </div>
                        <hr class="my-3" />
                        <p class="small text-muted mb-2">@L("Change password (optional)", "تغيير كلمة المرور (اختياري)")</p>
                        <div class="mb-3">
                            <label class="form-label" for="currentPassword">@L("Current password", "كلمة المرور الحالية")</label>
                            <input type="password" class="form-control" id="currentPassword" name="currentPassword"
                                autocomplete="current-password" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="newPassword">@L("New password", "كلمة المرور الجديدة")</label>
                            <input type="password" class="form-control" id="newPassword" name="newPassword"
                                minlength="6" autocomplete="new-password" />
                        </div>
                        <button type="submit" class="btn btn-primary">@L("Save changes", "حفظ التغييرات")</button>
                    </form>
                    <hr class="my-3" />
                    <p class="small text-muted mb-2">@L("End your session on this device.", "إنهاء جلستك على هذا الجهاز.")</p>
                    <button type="button" id="logoutLink" class="btn btn-outline-secondary">
                        <i class="bi bi-box-arrow-right me-2"></i>@L("Log out", "تسجيل الخروج")
                    </button>
                </div>

                <div class="account-card account-danger">
                    <h3 class="text-danger">@L("Delete account", "حذف الحساب")</h3>
                    <p class="small text-muted mb-3">@L("This permanently removes your profile, orders history shown here, and related data tied to your login. This cannot be undone.", "سيؤدي هذا إلى حذف ملفك الشخصي وسجل الطلبات والبيانات المرتبطة بحسابك نهائياً. لا يمكن التراجع عن هذا الإجراء.")</p>
                    <form asp-controller="Home" asp-action="DeleteAccount" method="post"
                        onsubmit="return confirm('@L("Delete your account permanently?", "هل تريد حذف حسابك نهائياً؟")');">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label" for="deletePassword">@L("Confirm with password", "التأكيد بكلمة المرور")</label>
                            <input type="password" class="form-control" id="deletePassword" name="deletePassword"
                                required autocomplete="current-password" />
                        </div>
                        <button type="submit" class="btn btn-outline-danger">@L("Delete my account", "حذف حسابي")</button>
                    </form>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="account-card">
                    <h3>@L("My orders", "طلباتي")</h3>
                    @if (Model.Orders == null || !Model.Orders.Any())
                    {
                        <p class="text-muted mb-0">@L("You have no orders yet.", "لا توجد لديك طلبات حتى الآن.") <a asp-controller="Home"
                                asp-action="Shop">@L("Browse the shop", "تصفح المتجر")</a>.</p>
                    }
                    else
                    {
                        @foreach (var order in Model.Orders)
                        {
                            <div class="order-card">
                                <div class="order-card-header">
                                    <strong>@L("Order", "طلب") #@order.Id</strong>
                                    <span>@order.OrderDate.ToLocalTime().ToString("g")</span>
                                    <span class="badge bg-secondary">@order.Status</span>
                                    <span class="ms-auto fw-semibold">@order.TotalAmount.ToString("N2") EGP</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(order.ShippingAddress) ||
                                                                !string.IsNullOrWhiteSpace(order.ShippingPhone))
                                {
                                    <div class="px-3 py-2 small border-bottom bg-white">
                                        @if (!string.IsNullOrWhiteSpace(order.ShippingAddress))
                                        {
                                            <div><span class="text-muted">@L("Ship to:", "الشحن إلى:")</span> @order.ShippingAddress</div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(order.ShippingPhone))
                                        {
                                            <div><span class="text-muted">@L("Phone:", "الهاتف:")</span> @order.ShippingPhone</div>
                                        }
                                    </div>
                                }
                                <div class="table-responsive">
                                    <table class="table table-sm mb-0 order-items-table">
                                        <thead>
                                            <tr>
                                                <th>@L("Product", "المنتج")</th>
                                                <th class="text-end">@L("Price", "السعر")</th>
                                                <th class="text-end">@L("Qty", "الكمية")</th>
                                                <th class="text-end">@L("Subtotal", "الإجمالي الفرعي")</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var line in order.Items)
                                            {
                                                <tr>
                                                    <td>@line.ProductName</td>
                                                    <td class="text-end">@line.Price.ToString("N2") EGP</td>
                                                    <td class="text-end">@line.Quantity</td>
                                                    <td class="text-end">@line.Subtotal.ToString("N2") EGP</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</section>
