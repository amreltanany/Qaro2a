@model ECommerce.Application.DTOs.Order.OrderResponseDto
@{
    var itemsSubtotal = Model.Items.Sum(i => i.Subtotal);
}
<div class="order-details-panel p-3 bg-light border-top">
    @if (!string.IsNullOrWhiteSpace(Model.ShippingAddress) || !string.IsNullOrWhiteSpace(Model.ShippingPhone))
    {
        <div class="small mb-3">
            @if (!string.IsNullOrWhiteSpace(Model.ShippingAddress))
            {
                <div><span class="text-muted">Ship to:</span> @Model.ShippingAddress</div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.ShippingPhone))
            {
                <div><span class="text-muted">Phone:</span> @Model.ShippingPhone</div>
            }
        </div>
    }

    @if (Model.Items == null || !Model.Items.Any())
    {
        <p class="text-muted mb-0 small">No line items recorded for this order.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-bordered mb-2 bg-white">
                <thead class="table-light">
                    <tr>
                        <th>Product</th>
                        <th class="text-end">Price</th>
                        <th class="text-end">Qty</th>
                        <th class="text-end">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td class="text-end">@item.Price.ToString("N2") EGP</td>
                            <td class="text-end">@item.Quantity</td>
                            <td class="text-end">@item.Subtotal.ToString("N2") EGP</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th colspan="3" class="text-end">Items subtotal</th>
                        <th class="text-end">@itemsSubtotal.ToString("N2") EGP</th>
                    </tr>
                    @if (Model.DeliveryFee > 0)
                    {
                        <tr>
                            <th colspan="3" class="text-end">Delivery fee</th>
                            <th class="text-end">@Model.DeliveryFee.ToString("N2") EGP</th>
                        </tr>
                    }
                    <tr>
                        <th colspan="3" class="text-end">Order total</th>
                        <th class="text-end">@Model.TotalAmount.ToString("N2") EGP</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
</div>
