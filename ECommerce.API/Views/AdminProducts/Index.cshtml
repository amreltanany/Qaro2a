@model IEnumerable<ECommerce.Application.DTOs.Product.ProductResponseDto>
@{
    ViewData["Title"] = "Products";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var search = ViewBag.Search as string;
}
<div class="dashboard-card card">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span>Products</span>
        <a asp-action="Create" class="btn btn-primary btn-dashboard"><i class="bi bi-plus-lg me-1"></i>Add Product</a>
    </div>
    <div class="card-body">
        <form method="get" class="mb-3 d-flex gap-2">
            <input type="text" name="search" value="@search" class="form-control" placeholder="Search by product, author, or date..." style="max-width: 280px;" />
            <button type="submit" class="btn btn-outline-secondary">Search</button>
        </form>
        <div class="table-responsive">
            <table class="table table-dashboard table-hover mb-0">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Author</th>
                        <th>Publish Date</th>
                        <th>Top Rated</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td>@p.Id</td>
                            <td>
                                @if (!string.IsNullOrEmpty(p.ImageUrl))
                                {
                                    <img src="@Url.Content(p.ImageUrl)" alt="" class="rounded" style="width: 48px; height: 48px; object-fit: cover;" />
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                            <td>@p.Name</td>
                            <td>@p.CategoryName</td>
                            <td>@p.Author</td>
                            <td>@p.PublishDate.ToString("yyyy-MM-dd")</td>
                            <td>@(p.TopRated ? "Yes" : "No")</td>
                            <td>@p.Price.ToString("N2")</td>
                            <td>@p.Stock</td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                                <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.Any())
        {
            <p class="text-muted text-center py-4 mb-0">No products found.</p>
        }
    </div>
</div>
