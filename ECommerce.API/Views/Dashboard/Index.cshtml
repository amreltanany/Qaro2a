@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}
<div class="dashboard-card card">
    <div class="card-header">Dashboard</div>
    <div class="card-body">
        <p class="text-muted mb-4">Welcome to the admin dashboard. Manage products, categories, and orders below.</p>
        <div class="row g-3">
            <div class="col-md-4">
                <a href="@Url.Action("Index", "AdminProducts")" class="text-decoration-none">
                    <div class="card border h-100 hover-shadow">
                        <div class="card-body d-flex align-items-center">
                            <div class="rounded-circle bg-primary bg-opacity-10 p-3 me-3">
                                <i class="bi bi-box-seam text-primary fs-4"></i>
                            </div>
                            <div>
                                <h5 class="card-title mb-0">Products</h5>
                                <p class="text-muted small mb-0">Create, edit, and delete products</p>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a href="@Url.Action("Index", "AdminCategories")" class="text-decoration-none">
                    <div class="card border h-100 hover-shadow">
                        <div class="card-body d-flex align-items-center">
                            <div class="rounded-circle bg-success bg-opacity-10 p-3 me-3">
                                <i class="bi bi-tags text-success fs-4"></i>
                            </div>
                            <div>
                                <h5 class="card-title mb-0">Categories</h5>
                                <p class="text-muted small mb-0">Manage product categories</p>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a href="@Url.Action("Index", "AdminOrders")" class="text-decoration-none">
                    <div class="card border h-100 hover-shadow">
                        <div class="card-body d-flex align-items-center">
                            <div class="rounded-circle bg-info bg-opacity-10 p-3 me-3">
                                <i class="bi bi-bag-check text-info fs-4"></i>
                            </div>
                            <div>
                                <h5 class="card-title mb-0">Orders</h5>
                                <p class="text-muted small mb-0">View orders and update status</p>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a href="@Url.Action("Index", "AdminPublishes")" class="text-decoration-none">
                    <div class="card border h-100 hover-shadow">
                        <div class="card-body d-flex align-items-center">
                            <div class="rounded-circle bg-warning bg-opacity-10 p-3 me-3">
                                <i class="bi bi-file-earmark-pdf text-warning fs-4"></i>
                            </div>
                            <div>
                                <h5 class="card-title mb-0">Publish</h5>
                                <p class="text-muted small mb-0">Review submissions and download PDFs</p>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a href="@Url.Action("Index", "AdminContacts")" class="text-decoration-none">
                    <div class="card border h-100 hover-shadow">
                        <div class="card-body d-flex align-items-center">
                            <div class="rounded-circle bg-secondary bg-opacity-10 p-3 me-3">
                                <i class="bi bi-envelope-paper text-secondary fs-4"></i>
                            </div>
                            <div>
                                <h5 class="card-title mb-0">Contact</h5>
                                <p class="text-muted small mb-0">Read contact form messages</p>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </div>
</div>
