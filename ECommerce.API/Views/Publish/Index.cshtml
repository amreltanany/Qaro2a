@{
    ViewData["Title"] = "Publish";
    var mobile = ViewBag.MobileNumber as string ?? string.Empty;
}

<section class="py-5">
    <div class="container" style="max-width: 720px;">
        <h2 class="mb-3">Publish with Qaro2a</h2>
        <p class="text-muted mb-4">
            Submit your manuscript as a PDF. Our team will review your submission and get back to you.
        </p>

        @if (TempData["PublishSuccess"] is string success)
        {
            <div class="alert alert-success" role="alert">@success</div>
        }

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-controller="Publish" asp-action="Index" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label for="mobileNumber" class="form-label">Mobile number</label>
                        <input type="tel" class="form-control" id="mobileNumber" name="mobileNumber"
                               value="@mobile" required maxlength="30" placeholder="+20 ..." />
                    </div>

                    <div class="mb-4">
                        <label for="pdfFile" class="form-label">Manuscript (PDF, max 5 MB)</label>
                        <input type="file" class="form-control" id="pdfFile" name="pdfFile" accept=".pdf,application/pdf" required />
                    </div>

                    <button type="submit" class="btn btn-primary">Submit</button>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</section>
