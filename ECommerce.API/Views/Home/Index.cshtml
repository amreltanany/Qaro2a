@model IList<ECommerce.Application.DTOs.Product.ProductResponseDto>
@{
    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var isArabic = string.Equals(currentCulture, "ar", StringComparison.OrdinalIgnoreCase);
    string L(string en, string ar) => isArabic ? ar : en;
    ViewData["Title"] = L("Home", "الرئيسية");
    string Q(string virtualPath, int width, string format, int quality = 82)
        => $"{Url.Content(virtualPath)}?width={width}&format={format}&quality={quality}";

    var heroWebp = Q("~/logo/Gemini_Generated_Image_g5fo4og5fo4og5fo.png", 1920, "webp", 80);
    var heroJpeg = Q("~/logo/Gemini_Generated_Image_g5fo4og5fo4og5fo.png", 1920, "jpeg", 82);
    var publishBannerUrl = Q("~/logo/test24.jpg", 1920, "jpeg", 82);
    var aboutBackgroundUrl = Q("~/logo/aboutUsBackgrpound.png", 1600, "jpeg", 78);
}

@section Head {
    <link rel="preload" as="image" href="@heroWebp" type="image/webp" fetchpriority="high" />
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

<!--Hero-->
<section class="overflow-hidden">
    <div class="w-100">
        <picture>
            <source type="image/webp" srcset="@heroWebp" />
            <img src="@heroJpeg" alt="@L("Qaro2a home hero", "واجهة قروءه الرئيسية")" class="img-fluid mb-4" data-aos="fade-up"
                width="1920" height="1080" decoding="async" fetchpriority="high"
                style="width:100%;height:auto">
        </picture>
    </div>
</section>
<!--Hero-->

<!--New Arrivals-->
<section id="billboard" class="overflow-hidden">
    <div class="container">
        <div class="row justify-content-center">
            <h1 class="section-title text-center mt-4" data-aos="fade-up">@L("New Collections", "إصدارات جديدة")</h1>
            <div class="col-md-6 text-center" data-aos="fade-up" data-aos-delay="300">
                <p>
                    @L("Every book in our collection is more than just pages-it is a perspective. At Qaro2a, we believe storytelling is the heartbeat of humanity. From curated bestsellers to hidden gems by independent voices, we provide a platform where every narrative finds its home and every reader finds their next adventure.", "كل كتاب في مجموعتنا ليس مجرد صفحات، بل منظور مختلف. في قروءه نؤمن أن السرد هو نبض الإنسانية. من الكتب الأكثر مبيعًا إلى الكنوز المخفية لأصوات مستقلة، نوفر منصة يجد فيها كل سرد موطنه ويجد فيها كل قارئ مغامرته القادمة.")
                </p>
            </div>
        </div>
        <div class="row">
            <div class="swiper main-swiper py-4" data-aos="fade-up" data-aos-delay="600">
                <div class="swiper-wrapper border-animation-left">
                    @foreach (var product in Model)
                    {
                        var rawImg = product.ImageUrl ?? "~/logo/Untitled_design-removebg-preview.png";
                        var productSrc = Url.Content(rawImg);
                        if (!productSrc.StartsWith("http", StringComparison.OrdinalIgnoreCase))
                        {
                            var q = productSrc.Contains('?', StringComparison.Ordinal) ? '&' : '?';
                            productSrc = $"{productSrc}{q}width=720&format=webp&quality=80";
                        }

                        <div class="swiper-slide">
                            <div class="banner-item image-zoom-effect">
                                <div class="image-holder">
                                    <a asp-controller="Home" asp-action="Shop">
                                        <img src="@productSrc"
                                            alt="@product.Name" class="img-fluid" loading="lazy" decoding="async"
                                            width="400" height="300"
                                            style="width: 100%; height: 300px; object-fit: cover;">
                                    </a>
                                </div>
                                <div class="banner-content py-4 px-2 px-md-3">
                                    <h5 class="element-title text-uppercase">
                                        <a href="index.html" class="item-anchor">@product.Name</a>
                                    </h5>
                                    <p>@product.Description (author)</p>
                                    <div class="btn-left">
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
<!--New Arrivals-->

<!--publish-->
<section class="overflow-hidden">
    <a href="#">
        <div class="w-100">
            <img src="@publishBannerUrl" alt="@L("Publish with Qaro2a", "انشر مع قروءه")" class="img-fluid" data-aos="fade-up"
                width="1920" height="600" loading="lazy" decoding="async" style="width:100%;height:auto">
        </div>
    </a>
</section>
<!--publish-->

<!--broadcast-aboutUs-->
<section class="home-about-section py-5 overflow-hidden" style="--about-bg: url('@aboutBackgroundUrl');">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-12 col-md-6">
                <h2>@L("About Us", "من نحن")</h2>
                <p class="mb-0">@L("Qaro2a is a platform for book lovers to discover and share their favorite books. We are a team of book lovers who are passionate about books and we believe that books are the best way to learn and grow.", "قروءه منصة لعشاق الكتب لاكتشاف كتبهم المفضلة ومشاركتها. نحن فريق شغوف بالقراءة ونؤمن أن الكتب هي أفضل طريق للتعلم والنمو.") <a asp-controller="Home" asp-action="About">@L("Read more", "اقرأ المزيد")</a></p>
            </div>
            <div class="col-12 col-md-6">
                <div class="ratio ratio-16x9">
                    <iframe width="560" height="315" src="https://www.youtube.com/embed/sVBZDAQQGCk?si=JrTsT0-V4xXo5RfA"
                        title="YouTube video player" loading="lazy"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                        referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
                </div>

                <div class="view_more">
                    <a href="https://www.youtube.com/@@Qaro2a/" target="_blank" rel="noopener noreferrer">@L("View more", "شاهد المزيد")</a>
                </div>
            </div>
        </div>
    </div>
</section>
