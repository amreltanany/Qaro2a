@section Scripts {
    <script>
        (function () {
            var openBtn = document.getElementById('videoOverlayOpen');
            var closeBtn = document.getElementById('videoOverlayClose');
            var screen = document.getElementById('videoOverlayScreen');

            if (!openBtn || !closeBtn || !screen) return;

            function setScreenState(open) {
                screen.classList.toggle('is-open', open);
                screen.setAttribute('aria-hidden', open ? 'false' : 'true');
                document.body.style.overflow = open ? 'hidden' : '';
            }

            openBtn.addEventListener('click', function () { setScreenState(true); });
            closeBtn.addEventListener('click', function () { setScreenState(false); });
            screen.addEventListener('click', function (event) {
                if (event.target === screen) setScreenState(false);
            });
        })();
    </script>
}
