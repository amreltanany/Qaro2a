<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(string.IsNullOrWhiteSpace(ViewData["Title"] as string) ? "Dashboard" : ViewData["Title"]) | qaro2a</title>
    <link rel="icon" type="image/png" href="~/logo/429827302_747764070661978_6323408778619379006_n-removebg-preview.png" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
</head>
<body class="dashboard-body">
    <header class="dashboard-header shadow-sm">
        <div class="container-fluid d-flex justify-content-between align-items-center py-3">
            <a href="@Url.Action("Index", "Dashboard")" class="text-decoration-none text-dark fw-bold">
                <i class="bi bi-grid-1x2 me-2"></i>Admin Dashboard
            </a>
            <div class="d-flex align-items-center gap-3">
                <a class="btn btn-outline-secondary btn-sm" href="@Url.Action("Index", "Home")">
                    <i class="bi bi-house me-1"></i>Back to Home
                </a>
                <a class="btn btn-outline-primary btn-sm" href="@Url.Action("Index", "AdminProducts")">
                    <i class="bi bi-box-seam me-1"></i>Products
                </a>
                <a class="btn btn-outline-primary btn-sm" href="@Url.Action("Index", "AdminCategories")">
                    <i class="bi bi-tags me-1"></i>Categories
                </a>
                <a class="btn btn-outline-primary btn-sm" href="@Url.Action("Index", "AdminOrders")">
                    <i class="bi bi-bag-check me-1"></i>Orders
                </a>
                <a class="btn btn-outline-primary btn-sm" href="@Url.Action("Index", "AdminPublishes")">
                    <i class="bi bi-file-earmark-pdf me-1"></i>Publish
                </a>
                <a class="btn btn-outline-primary btn-sm" href="@Url.Action("Index", "AdminContacts")">
                    <i class="bi bi-envelope-paper me-1"></i>Contact
                </a>
                <a class="btn btn-outline-danger btn-sm" href="@Url.Action("Logout", "Dashboard")">
                    <i class="bi bi-box-arrow-right me-1"></i>Log out
                </a>
            </div>
        </div>
    </header>
    <main class="dashboard-main container-fluid py-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @RenderBody()
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
