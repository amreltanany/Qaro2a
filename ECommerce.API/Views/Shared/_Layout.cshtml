@using System.Text.Json
@using Microsoft.Extensions.Options
@using ECommerce.API.Options
@inject IOptions<SeoOptions> SeoOptions
@{
    var rawTitle = ViewData["Title"] as string;
    string pageTitle;
    if (!string.IsNullOrWhiteSpace(rawTitle))
    {
        pageTitle = rawTitle.Trim();
    }
    else
    {
        var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
        var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
        if (controller == "Home")
        {
            pageTitle = action switch
            {
                "Index" => "Home",
                "Shop" => "Shop",
                "MyAccount" => "My Account",
                "Podcast" => "Podcast",
                "PrivacyPolicy" => "Privacy Policy",
                "TermsOfService" => "Terms of Service",
                _ => string.IsNullOrEmpty(action) ? "Home" : string.Concat(action.Select((c, i) => i > 0 && char.IsUpper(c) ? " " + c : c.ToString()))
            };
        }
        else if (string.Equals(action, "Index", StringComparison.OrdinalIgnoreCase))
        {
            pageTitle = string.IsNullOrEmpty(controller) ? "Home" : controller;
        }
        else if (!string.IsNullOrEmpty(action))
        {
            pageTitle = string.Concat(action.Select((c, i) => i > 0 && char.IsUpper(c) ? " " + c : c.ToString()));
        }
        else
        {
            pageTitle = "Home";
        }
    }

    var seo = SeoOptions.Value;
    var req = Context.Request;
    var baseUrl = string.IsNullOrWhiteSpace(seo.BaseUrl)
        ? $"{req.Scheme}://{req.Host}"
        : seo.BaseUrl.TrimEnd('/');
    var canonicalUrl = $"{baseUrl}{req.PathBase}{req.Path}";
    var metaDescription = ViewData["MetaDescription"] as string ?? seo.DefaultDescription;
    var ogTitle = $"{pageTitle} | {seo.SiteName}";
    var ogImageRaw = ViewData["OgImage"] as string ?? seo.DefaultOgImage;
    string? ogImagePath = null;
    if (!string.IsNullOrWhiteSpace(ogImageRaw))
    {
        var trimmed = ogImageRaw.Trim();
        ogImagePath = trimmed.StartsWith("~/", StringComparison.Ordinal)
            ? Url.Content(trimmed)
            : (trimmed.StartsWith('/') ? trimmed : "/" + trimmed);
    }
    var ogImageAbsolute = string.IsNullOrEmpty(ogImagePath) ? null : $"{baseUrl}{ogImagePath}";
    var metaKeywords = ViewData["MetaKeywords"] as string ?? seo.DefaultKeywords;

    var orgLd = new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "Organization",
        ["name"] = seo.SiteName,
        ["url"] = baseUrl,
        ["logo"] = ogImageAbsolute
    };
    if (seo.SameAs is { Length: > 0 } sameAs)
        orgLd["sameAs"] = sameAs;
    var orgJsonLd = JsonSerializer.Serialize(orgLd);
    string? twitterSite = null;
    if (!string.IsNullOrWhiteSpace(seo.TwitterHandle))
    {
        var h = seo.TwitterHandle.Trim();
        twitterSite = h.StartsWith('@') ? h : "@" + h;
    }
}
<!DOCTYPE html>
<html lang="en">

<head>
    <title>@ogTitle</title>
    <link rel="canonical" href="@canonicalUrl" />
    <link rel="icon" type="image/png" href="~/logo/429827302_747764070661978_6323408778619379006_n-removebg-preview.png" asp-append-version="true" />
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="format-detection" content="telephone=no">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="author" content="@seo.SiteName">
    @if (!string.IsNullOrWhiteSpace(metaKeywords))
    {
        <meta name="keywords" content="@metaKeywords" />
    }
    <meta name="description" content="@metaDescription" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="@seo.SiteName" />
    <meta property="og:title" content="@ogTitle" />
    <meta property="og:description" content="@metaDescription" />
    <meta property="og:url" content="@canonicalUrl" />
    <meta property="og:locale" content="@seo.OgLocale" />
    @if (!string.IsNullOrEmpty(ogImageAbsolute))
    {
        <meta property="og:image" content="@ogImageAbsolute" />
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@ogTitle" />
    <meta name="twitter:description" content="@metaDescription" />
    @if (twitterSite != null)
    {
        <meta name="twitter:site" content="@twitterSite" />
    }
    @if (!string.IsNullOrEmpty(ogImageAbsolute))
    {
        <meta name="twitter:image" content="@ogImageAbsolute" />
    }
    <meta name="user-id" content="guest">
    <script type="application/ld+json">@Html.Raw(orgJsonLd)</script>
    @await RenderSectionAsync("Head", required: false)
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
        crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.css" media="print"
        onload="this.media='all'" />
    <noscript>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.css" />
    </noscript>
    <link rel="stylesheet" type="text/css" href="~/css/vendor.css" asp-append-version="true">
    <link rel="stylesheet" type="text/css" href="~/style.css" asp-append-version="true">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Jost:wght@400;500;600;700&family=Marcellus&display=swap"
        rel="stylesheet">
    <style>
        .nav-auth-hidden {
            display: none !important;
        }

        .navbar .nav-item:not(.nav-publish-btn) .nav-link {
            border-bottom: 2px solid transparent;
            transition: border-color 0.2s ease, color 0.2s ease;
        }

        .navbar .nav-item:not(.nav-publish-btn) .nav-link:hover {
            border-bottom-color: #4da3ff;
        }

        .navbar .nav-link.active {
            color: #4da3ff !important;
            font-weight: 600;
            border-bottom: 2px solid #4da3ff;
        }
    </style>

</head>

