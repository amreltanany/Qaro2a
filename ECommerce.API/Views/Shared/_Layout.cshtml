    <script>
        (function () {
            if (new URLSearchParams(window.location.search).get('logout') === '1') {
                localStorage.removeItem('token');
                localStorage.removeItem('userId');
                document.cookie = 'token=; expires=Thu, 01 Jan 1970 00:00:01 GMT; path=/';
                if (window.history.replaceState) {
                    var clean = window.location.pathname + window.location.hash;
                    window.history.replaceState({}, '', clean);
                }
            }
            function applyAuthState() {
                var token = typeof localStorage !== 'undefined' && localStorage.getItem('token');
                var guestEls = document.querySelectorAll('.nav-auth-guest');
                var authOnlyEls = document.querySelectorAll('.nav-auth-only');
                if (token) {
                    guestEls.forEach(function (el) { el.classList.add('nav-auth-hidden'); });
                    authOnlyEls.forEach(function (el) { el.classList.remove('nav-auth-hidden'); });
                } else {
                    guestEls.forEach(function (el) { el.classList.remove('nav-auth-hidden'); });
                    authOnlyEls.forEach(function (el) { el.classList.add('nav-auth-hidden'); });
                }
            }
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', applyAuthState);
            } else {
                applyAuthState();
            }
            var logoutLink = document.getElementById('logoutLink');
            if (logoutLink) {
                logoutLink.addEventListener('click', function (e) {
                    e.preventDefault();
                    window.location.href = '/Dashboard/Logout';
                });
            }
        })();
    </script>
